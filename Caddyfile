:8080 {
  encode gzip

  handle_path /api/asr/* {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:asr:8000}
  }

  handle /healthz {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:asr:8000}
  }

  handle /v1/audio/transcriptions {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:asr:8000}
  }

  handle /api/transcriptions {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:asr:8000}
  }

  handle {
    reverse_proxy frontend:8000
  }
}

:18000 {
  encode gzip
  reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:asr:8000}
}
