:8080 {
  encode gzip

  handle_path /api/asr/* {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:funasr-server:8000}
  }

  handle /healthz {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:funasr-server:8000}
  }

  handle /v1/audio/transcriptions {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:funasr-server:8000}
  }

  handle /api/transcriptions {
    reverse_proxy {$CUT_SUITE_ASR_UPSTREAM:funasr-server:8000}
  }

  handle {
    reverse_proxy {$CUT_SUITE_FRONTEND_UPSTREAM:video-cuter-full:8000}
  }
}

:18000 {
